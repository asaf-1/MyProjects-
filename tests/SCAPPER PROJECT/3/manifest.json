{
  "manifest_version": 3,
  "name": "Universal Downloader",
  "version": "0.2.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "downloads", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "sw.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
